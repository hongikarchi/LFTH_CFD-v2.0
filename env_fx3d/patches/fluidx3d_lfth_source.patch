+	if(refill_col_h_cfg < 0) refill_col_h_cfg = 0;
+	int   emit_col_h_cfg = (int)get_num(cs, "nozzle_emit_col_h", 8.0f);
+	if(emit_col_h_cfg < 1) emit_col_h_cfg = 1;
+	int   pulse_depth_cfg = (int)get_num(cs, "nozzle_pulse_depth_h", -1.0f);
