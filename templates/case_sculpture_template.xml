<?xml version="1.0" encoding="UTF-8" ?>
<!--
    LFTH_CFD v2.0 — Nozzle → Sculpture → Pond case template

    Placeholders (replaced by scripts/run_case.py):
        {{dp}}                  Initial inter-particle distance (m)
        {{timemax}}             Simulation duration (s)
        {{timeout}}             Output save interval (s)
        {{stl_path}}            Absolute path to sculpture STL
        {{stl_scale}}           Scaling factor for STL (sculpture_size)
        {{stl_rotate_z_deg}}    Rotation about Z axis in degrees (sculpture_angle)
        {{stl_move_z}}          Vertical placement (sculpture_height)
        {{nozzle_x}} {{nozzle_y}}    Nozzle horizontal position (m)
        {{nozzle_z}}                  Nozzle z height (m), default 2.5
        {{nozzle_diameter}}          Nozzle inlet square side (m)
        {{nozzle_angle_x_deg}}       Tilt about X-axis (deg)
        {{nozzle_angle_y_deg}}       Tilt about Y-axis (deg)
        {{flow_velocity}}            Inlet velocity magnitude (m/s)
        {{vel_x}} {{vel_y}} {{vel_z}}    Inlet velocity vector components
                                         (run_case.py computes from angle * flow_velocity)
        {{domain_xmin}} ... {{domain_zmax}}  Simulation domain AABB
        {{pond_xmin}} {{pond_ymin}} {{pond_xsize}} {{pond_ysize}} {{pond_thickness}}
-->
<case app="LFTH_CFD v2.0" date="2026-05-25">
    <casedef>
        <constantsdef>
            <gravity x="0" y="0" z="-9.81" comment="Gravitational acceleration" units_comment="m/s^2" />
            <rhop0 value="1000" comment="Reference density of water" units_comment="kg/m^3" />
            <rhopgradient value="2" comment="Initial density gradient (2=water column)" />
            <hswl value="0.05" auto="false" comment="Maximum still water level" units_comment="m" />
            <gamma value="7" comment="Politropic constant" />
            <speedsystem value="5" auto="false" comment="Reference system speed (m/s) — set above max expected velocity" />
            <coefsound value="20" />
            <speedsound value="100" auto="false" comment="Sound speed (m/s). Higher = more numerical stiffness" />
            <coefh value="1.0" />
            <cflnumber value="0.2" />
        </constantsdef>

        <mkconfig boundcount="240" fluidcount="9" />

        <geometry>
            <definition dp="{{dp}}" units_comment="m">
                <pointmin x="{{domain_xmin}}" y="{{domain_ymin}}" z="{{domain_zmin}}" />
                <pointmax x="{{domain_xmax}}" y="{{domain_ymax}}" z="{{domain_zmax}}" />
            </definition>

            <commands>
                <mainlist>
                    <setshapemode>actual | bound</setshapemode>
                    <setdrawmode mode="full" />

                    <!-- ============================================================
                         POND (catchment) — bottom box, MK=10
                         ============================================================ -->
                    <setmkbound mk="10" />
                    <drawbox>
                        <boxfill>solid</boxfill>
                        <point x="{{pond_xmin}}" y="{{pond_ymin}}" z="0" />
                        <size x="{{pond_xsize}}" y="{{pond_ysize}}" z="{{pond_thickness}}" />
                    </drawbox>

                    <!-- ============================================================
                         SCULPTURE — STL import, MK=20
                         ============================================================ -->
                    <setmkbound mk="20" />
                    <drawfilestl file="{{stl_path}}" autofill="false">
                        <drawmove x="0" y="0" z="{{stl_move_z}}" />
                        <drawrotate angx="0" angy="0" angz="{{stl_rotate_z_deg}}" />
                        <drawscale x="{{stl_scale}}" y="{{stl_scale}}" z="{{stl_scale}}" />
                    </drawfilestl>

                    <!-- ============================================================
                         FLOOR (containment) — large flat boundary below pond, MK=0
                         Avoids particles falling through bottom of domain
                         ============================================================ -->
                    <setmkbound mk="0" />
                    <drawbox>
                        <boxfill>solid</boxfill>
                        <point x="{{domain_xmin}}" y="{{domain_ymin}}" z="{{domain_zmin}}" />
                        <size x="{{domain_xsize}}" y="{{domain_ysize}}" z="0.01" />
                    </drawbox>

                    <!-- ============================================================
                         NOZZLE INLET — fluid emission zone, MK_fluid=1
                         Small box at z=nozzle_z, particles emitted downward (or tilted)
                         ============================================================ -->
                    <setmkfluid mk="1" />
                    <drawbox>
                        <boxfill>bottom</boxfill>
                        <point
                            x="{{nozzle_x_minus_half}}"
                            y="{{nozzle_y_minus_half}}"
                            z="{{nozzle_z}}" />
                        <size
                            x="{{nozzle_diameter}}"
                            y="{{nozzle_diameter}}"
                            z="{{nozzle_thickness}}" />
                    </drawbox>

                    <_shapeout file="" />
                </mainlist>
            </commands>
        </geometry>

        <initials>
            <!-- Initial velocity for inlet particles -->
            <velocity mkfluid="1" x="{{vel_x}}" y="{{vel_y}}" z="{{vel_z}}" />
        </initials>

        <normals active="true">
            <!-- Pond top face faces up -->
            <norplane mkbound="10">
                <point auto="true" />
                <normal x="0" y="0" z="1" />
                <maxdisth v="2.5" />
            </norplane>
            <!-- Floor faces up -->
            <norplane mkbound="0">
                <point auto="true" />
                <normal x="0" y="0" z="1" />
                <maxdisth v="2.5" />
            </norplane>
        </normals>
    </casedef>

    <execution>
        <special>
            <inout>
                <memoryresize size0="2" size="4" comment="Memory growth for inflow" />
                <determlimit value="1e+3" />

                <!-- Top nozzle inlet zone (3D) -->
                <inoutzone>
                    <refilling value="0" comment="0:Simple full" />
                    <inputtreatment value="2" comment="2:Remove fluid for inlet (recommended)" />
                    <layers value="4" />
                    <zone3d comment="3D inlet zone — bottom face of nozzle box">
                        <particles mkfluid="1" direction="bottom" />
                    </zone3d>
                    <imposevelocity mode="0" comment="0:fixed value">
                        <velocity v="{{flow_velocity}}" comment="Magnitude m/s" units_comment="m/s" />
                    </imposevelocity>
                    <imposerhop mode="0" />
                </inoutzone>
            </inout>
        </special>

        <parameters>
            <parameter key="SavePosDouble" value="0" />
            <parameter key="Boundary" value="2" comment="mDBC" />
            <parameter key="StepAlgorithm" value="2" comment="Symplectic" />
            <parameter key="Kernel" value="2" comment="Wendland" />
            <parameter key="ViscoTreatment" value="1" comment="1:Artificial" />
            <parameter key="Visco" value="0.01" comment="Artificial viscosity coefficient" />
            <parameter key="ViscoBoundFactor" value="1" />
            <parameter key="DensityDT" value="3" comment="3:Fourtakas(full)" />
            <parameter key="DensityDTvalue" value="0.1" />
            <parameter key="Shifting" value="0" />
            <parameter key="RigidAlgorithm" value="1" comment="1:SPH for bounds" />
            <parameter key="CoefDtMin" value="0.05" />
            <parameter key="DtIni" value="0" />
            <parameter key="DtMin" value="0" />
            <parameter key="DtAllParticles" value="0" comment="DT computed from fluid only" />
            <parameter key="TimeMax" value="{{timemax}}" units_comment="s" />
            <parameter key="TimeOut" value="{{timeout}}" units_comment="s" />
            <!-- PartsOutMax is deprecated; particles leaving the domain are captured by PartVTKOut -->
            <parameter key="MinFluidStop" value="0.1" comment="Stop simulation if fluid count drops to 10% of initial" />
            <parameter key="RhopOutMin" value="700" />
            <parameter key="RhopOutMax" value="1300" />
            <simulationdomain comment="Domain auto-sized from particles with margin">
                <posmin x="default - 10%" y="default - 10%" z="default - 10%" />
                <posmax x="default + 10%" y="default + 10%" z="default + 10%" />
            </simulationdomain>
        </parameters>
    </execution>
</case>
